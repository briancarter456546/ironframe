{
  "$schema": "ironframe/io-schema/1.0",
  "schema_id": "audit.event",
  "version": "1.0",
  "description": "AuditEvent -- immutable record of a significant system event. Compliance-ready (HIPAA/FINRA/SOC2).",
  "fields": {
    "event_id": {"type": "string", "required": true, "description": "UUID for this event"},
    "timestamp": {"type": "string", "required": true, "description": "ISO 8601 UTC timestamp"},
    "session_id": {"type": "string", "required": false, "default": ""},
    "event_type": {"type": "string", "required": true, "description": "model_call, hook_fire, skill_load, escalation, schema_validation, state_transition, stream_open, stream_close, stream_error"},
    "component": {"type": "string", "required": true, "description": "Dotted path: mal.client, sae.judge, etc."},
    "input_hash": {"type": "string", "required": false, "default": "", "description": "SHA-256 of raw input (PHI/PII safety)"},
    "input_length": {"type": "int", "required": false, "default": 0, "constraints": {"min": 0}},
    "output_summary": {"type": "string", "required": false, "default": "", "description": "Truncated output"},
    "output_hash": {"type": "string", "required": false, "default": ""},
    "confidence_score": {"type": "float", "required": false, "default": -1.0},
    "confidence_band": {"type": "enum", "required": false, "enum_values": ["HIGH", "MEDIUM", "LOW", "UNACCEPTABLE", "UNSCORED"], "default": "UNSCORED"},
    "confidence_signals": {"type": "dict", "required": false, "default": {}, "description": "Per-signal breakdown"},
    "model_id": {"type": "string", "required": false, "default": ""},
    "provider": {"type": "string", "required": false, "default": ""},
    "tokens_in": {"type": "int", "required": false, "default": 0, "constraints": {"min": 0}},
    "tokens_out": {"type": "int", "required": false, "default": 0, "constraints": {"min": 0}},
    "cost_usd": {"type": "float", "required": false, "default": 0.0, "constraints": {"min": 0.0}},
    "hook_results": {"type": "list", "required": false, "default": [], "items_type": "dict"},
    "active_adapters": {"type": "list", "required": false, "default": [], "items_type": "string"},
    "retention_class": {"type": "string", "required": false, "default": "default"},
    "data_lineage": {"type": "dict", "required": false, "default": {}, "description": "Source input IDs, reasoning chain reference"},
    "is_streaming": {"type": "bool", "required": false, "default": false},
    "stream_status": {"type": "enum", "required": false, "enum_values": ["", "open", "closed", "error"], "default": ""},
    "error": {"type": "string", "required": false, "default": ""},
    "error_type": {"type": "string", "required": false, "default": ""},
    "schema_version": {"type": "string", "required": false, "default": "1.0"}
  },
  "required": ["event_id", "timestamp", "event_type", "component"]
}
