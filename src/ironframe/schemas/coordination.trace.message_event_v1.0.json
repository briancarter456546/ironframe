{
  "$schema": "ironframe/io-schema/1.0",
  "schema_id": "coordination.trace.message_event",
  "version": "1.0",
  "description": "Trace event for inter-agent coordination messages. Consumed by C18 for conformance.",
  "fields": {
    "event_id": {"type": "string", "required": true},
    "event_type": {"type": "enum", "required": true, "enum_values": ["coordination_message"]},
    "component_id": {"type": "enum", "required": true, "enum_values": ["C14"]},
    "timestamp": {"type": "string", "required": true},
    "scenario_id": {"type": "string", "required": true},
    "message_id": {"type": "string", "required": true},
    "message_type": {"type": "enum", "required": true, "enum_values": ["ASSIGNMENT", "RESULT", "QUERY", "ESCALATION", "HEARTBEAT", "HALT"]},
    "sender_agent_id": {"type": "string", "required": true},
    "receiver_agent_id": {"type": "string", "required": true},
    "sender_trust_tier": {"type": "int", "required": true, "constraints": {"min": 0, "max": 4}},
    "receiver_declared_tier": {"type": "int", "required": true, "constraints": {"min": 0, "max": 4}},
    "effective_tier": {"type": "int", "required": true, "constraints": {"min": 0, "max": 4}, "description": "min(receiver_declared_tier, sender_trust_tier)"},
    "parent_task_id": {"type": "string", "required": true},
    "subtask_id": {"type": "string", "required": true},
    "requires_ack": {"type": "bool", "required": true},
    "audit_logged": {"type": "bool", "required": true}
  },
  "required": ["event_id", "event_type", "component_id", "timestamp", "scenario_id", "message_id", "message_type", "sender_agent_id", "receiver_agent_id", "sender_trust_tier", "receiver_declared_tier", "effective_tier", "parent_task_id", "subtask_id", "requires_ack", "audit_logged"]
}
