{
  "$schema": "ironframe/io-schema/1.0",
  "schema_id": "coordination.trace.lock_event",
  "version": "1.0",
  "description": "Trace event for shared resource lock operations. C12 lock manager mediated.",
  "fields": {
    "event_id": {"type": "string", "required": true},
    "event_type": {"type": "enum", "required": true, "enum_values": ["resource_lock"]},
    "component_id": {"type": "enum", "required": true, "enum_values": ["C14"]},
    "timestamp": {"type": "string", "required": true},
    "scenario_id": {"type": "string", "required": true},
    "resource_id": {"type": "string", "required": true},
    "requesting_agent_id": {"type": "string", "required": true},
    "subtask_id": {"type": "string", "required": true},
    "graph_priority": {"type": "int", "required": true, "constraints": {"min": 0}},
    "assignment_timestamp": {"type": "string", "required": true},
    "queue_position": {"type": "int", "required": true, "constraints": {"min": 0}},
    "disposition": {"type": "enum", "required": true, "enum_values": ["GRANTED", "QUEUED", "RELEASED", "DENIED"]},
    "lock_manager_component": {"type": "enum", "required": true, "enum_values": ["C12"]},
    "audit_logged": {"type": "bool", "required": true}
  },
  "required": ["event_id", "event_type", "component_id", "timestamp", "scenario_id", "resource_id", "requesting_agent_id", "subtask_id", "graph_priority", "assignment_timestamp", "queue_position", "disposition", "lock_manager_component", "audit_logged"]
}
