{
  "$schema": "ironframe/io-schema/1.0",
  "schema_id": "coordination.trace.loop_event",
  "version": "1.0",
  "description": "Trace event for coordination loop detection.",
  "fields": {
    "event_id": {"type": "string", "required": true},
    "event_type": {"type": "enum", "required": true, "enum_values": ["loop_detected"]},
    "component_id": {"type": "enum", "required": true, "enum_values": ["C14"]},
    "timestamp": {"type": "string", "required": true},
    "scenario_id": {"type": "string", "required": true},
    "subtask_id": {"type": "string", "required": true},
    "agent_id": {"type": "string", "required": true},
    "repeated_message_type": {"type": "string", "required": true},
    "repeat_count": {"type": "int", "required": true, "constraints": {"min": 1}},
    "threshold": {"type": "int", "required": true, "constraints": {"min": 1}},
    "disposition": {"type": "enum", "required": true, "enum_values": ["WARN", "HALT"]},
    "audit_logged": {"type": "bool", "required": true}
  },
  "required": ["event_id", "event_type", "component_id", "timestamp", "scenario_id", "subtask_id", "agent_id", "repeated_message_type", "repeat_count", "threshold", "disposition", "audit_logged"]
}
